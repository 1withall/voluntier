# Environment configuration
ENVIRONMENT=development
DEBUG=true

# Database configuration
DATABASE_URL=postgresql+asyncpg://voluntier_user:voluntier_password@localhost:5432/voluntier
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# Redis configuration  
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_RETRY_ON_TIMEOUT=true
REDIS_SOCKET_TIMEOUT=5

# Neo4j configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_DATABASE=voluntier

# Temporal configuration
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=voluntier-task-queue
TEMPORAL_WORKFLOW_EXECUTION_TIMEOUT=3600
TEMPORAL_WORKFLOW_RUN_TIMEOUT=600
TEMPORAL_WORKFLOW_TASK_TIMEOUT=10
TEMPORAL_ACTIVITY_START_TO_CLOSE_TIMEOUT=60
TEMPORAL_ACTIVITY_HEARTBEAT_TIMEOUT=30

# Security configuration
SECRET_KEY=your-super-secret-key-change-in-production-please
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7
SECURITY_PASSWORD_RESET_EXPIRE_MINUTES=15
SECURITY_EMAIL_VERIFICATION_EXPIRE_HOURS=24

# LLM configuration
LLM_VLLM_BASE_URL=http://localhost:8000
LLM_OPENAI_API_KEY=
LLM_DEFAULT_MODEL=microsoft/DialoGPT-medium
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30

# Observability configuration
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_LOG_FORMAT=json
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_TRACING_ENABLED=true
OBSERVABILITY_PROMETHEUS_PORT=9090
OBSERVABILITY_JAEGER_ENDPOINT=

# Agent configuration
AGENT_MAX_RETRY_ATTEMPTS=3
AGENT_RETRY_BACKOFF_FACTOR=2.0
AGENT_MAX_PARALLEL_WORKFLOWS=10

# CORS configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Application settings
APP_NAME=Voluntier
APP_VERSION=0.1.0
API_PREFIX=/api/v1